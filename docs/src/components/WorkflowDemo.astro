---
/**
 * Interactive workflow graph demo for the landing page.
 * Uses the real workflow-graph WASM library (canvas renderer)
 * with simulated job execution to showcase the actual product.
 */
---

<div class="demo-wrapper" id="demo-wrapper">
  <div class="demo-header">
    <div class="demo-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <span class="demo-title">ci.yml — workflow run</span>
    <div class="demo-controls">
      <span class="demo-status" id="demo-run-status"></span>
      <button class="demo-btn" id="demo-run" aria-label="Run workflow">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor">
          <path d="M4 2l10 6-10 6z"/>
        </svg>
        Run
      </button>
    </div>
  </div>

  <!-- Status bar -->
  <div class="demo-statusbar" id="demo-statusbar">
    <span class="status-chip queued"><span class="chip-dot"></span><span id="count-queued">8</span> queued</span>
    <span class="status-chip running"><span class="chip-dot"></span><span id="count-running">0</span> running</span>
    <span class="status-chip success"><span class="chip-dot"></span><span id="count-success">0</span> success</span>
    <span class="status-chip failure"><span class="chip-dot"></span><span id="count-failure">0</span> failure</span>
  </div>

  <!-- Graph view (real WASM canvas) -->
  <div class="demo-view" id="view-graph">
    <canvas id="workflow-canvas" tabindex="0"></canvas>
  </div>

  <!-- Log panel -->
  <div class="demo-logpanel" id="demo-logpanel">
    <div class="log-header">
      <span class="log-title" id="log-title"></span>
      <button class="log-close" id="log-close" aria-label="Close logs">&times;</button>
    </div>
    <pre class="log-content" id="log-content"></pre>
  </div>
</div>

<style is:global>
  .demo-wrapper {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    overflow: hidden;
    max-width: 920px;
    margin: 2rem auto;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .demo-wrapper .demo-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }

  .demo-wrapper .demo-dots { display: flex; gap: 6px; }
  .demo-wrapper .dot { width: 12px; height: 12px; border-radius: 50%; }
  .demo-wrapper .dot.red { background: #ff5f57; }
  .demo-wrapper .dot.yellow { background: #febc2e; }
  .demo-wrapper .dot.green { background: #28c840; }

  .demo-wrapper .demo-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 13px;
    color: #8b949e;
    flex: 1;
  }

  .demo-wrapper .demo-controls { display: flex; align-items: center; gap: 10px; }

  .demo-wrapper .demo-status {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    color: #8b949e;
    transition: color 0.3s;
  }

  .demo-wrapper .demo-btn {
    all: unset;
    display: flex;
    align-items: center;
    gap: 6px;
    background: #238636;
    border: 1px solid #2ea043;
    border-radius: 6px;
    color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    padding: 4px 12px;
    line-height: 1.4;
    box-sizing: border-box;
    transition: background 0.15s;
  }

  .demo-wrapper .demo-btn:hover { background: #2ea043; }
  .demo-wrapper .demo-btn:disabled { background: #21262d; border-color: #30363d; color: #484f58; cursor: default; }

  /* Status bar */
  .demo-wrapper .demo-statusbar {
    display: flex;
    gap: 16px;
    padding: 8px 16px;
    background: #0d1117;
    border-bottom: 1px solid #21262d;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
  }

  .demo-wrapper .status-chip { display: flex; align-items: center; gap: 5px; color: #8b949e; }
  .demo-wrapper .chip-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .demo-wrapper .status-chip.queued .chip-dot { background: #484f58; }
  .demo-wrapper .status-chip.running .chip-dot { background: #d29922; }
  .demo-wrapper .status-chip.success .chip-dot { background: #238636; }
  .demo-wrapper .status-chip.failure .chip-dot { background: #da3633; }

  .demo-wrapper .demo-view { min-height: 340px; }

  .demo-wrapper #workflow-canvas {
    display: block;
    width: 100%;
    height: 380px;
    background: #0d1117;
  }

  /* Log panel */
  .demo-wrapper .demo-logpanel { display: none; background: #161b22; border-top: 1px solid #30363d; max-height: 140px; overflow: hidden; }
  .demo-wrapper .demo-logpanel.visible { display: block; }
  .demo-wrapper .log-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; border-bottom: 1px solid #21262d; }
  .demo-wrapper .log-title { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif; font-size: 12px; font-weight: 600; color: #c9d1d9; }
  .demo-wrapper .log-close { all: unset; color: #8b949e; cursor: pointer; font-size: 18px; line-height: 1; padding: 0 4px; }
  .demo-wrapper .log-close:hover { color: #c9d1d9; }
  .demo-wrapper .log-content { padding: 10px 16px; margin: 0; font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace; font-size: 12px; line-height: 1.6; color: #8b949e; overflow-y: auto; max-height: 90px; }
</style>

<script>
  async function initDemo() {
    const BASE = import.meta.env.BASE_URL || '/workflow-graph/';
    const wasmUrl = `${BASE}wasm/workflow_graph_web.js`;

    const wasmBinaryUrl = `${BASE}wasm/github_graph_web_bg.wasm`;

    // Dynamically import the WASM module
    let wasmModule: any;
    try {
      wasmModule = await import(/* @vite-ignore */ wasmUrl);
      await wasmModule.default(wasmBinaryUrl);
    } catch (e) {
      console.error('Failed to load WASM module:', e);
      return;
    }

    const { render_workflow, update_workflow_data } = wasmModule;

    const CANVAS_ID = 'workflow-canvas';

    // --- Resize canvas to match container ---
    function resizeCanvas() {
      const canvas = document.getElementById(CANVAS_ID) as HTMLCanvasElement;
      if (!canvas) return;
      const rect = canvas.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
    }

    // --- Workflow data (matches ci.yml / Workflow::sample()) ---
    function makeWorkflow(): any {
      return {
        id: 'ci-1',
        name: 'ci.yml',
        trigger: 'on: push',
        jobs: [
          { id: 'unit-tests', name: 'Unit Tests', status: 'queued', command: "echo 'Running unit tests' && sleep 2", duration_secs: null, started_at: null, depends_on: [], output: null, required_labels: [], max_retries: 1, attempt: 0 },
          { id: 'lint', name: 'Lint', status: 'queued', command: "echo 'Running linter' && sleep 1", duration_secs: null, started_at: null, depends_on: [], output: null, required_labels: [], max_retries: 0, attempt: 0 },
          { id: 'typecheck', name: 'Typecheck', status: 'queued', command: "echo 'Running typecheck' && sleep 2", duration_secs: null, started_at: null, depends_on: [], output: null, required_labels: [], max_retries: 0, attempt: 0 },
          { id: 'build', name: 'Build', status: 'queued', command: "echo 'Building project' && sleep 3", duration_secs: null, started_at: null, depends_on: ['unit-tests', 'lint', 'typecheck'], output: null, required_labels: ['linux'], max_retries: 0, attempt: 0 },
          { id: 'deploy-db', name: 'Deploy DB Migrations', status: 'queued', command: "echo 'Deploying DB migrations' && sleep 1", duration_secs: null, started_at: null, depends_on: ['build'], output: null, required_labels: ['linux', 'aws'], max_retries: 0, attempt: 0 },
          { id: 'e2e-tests', name: 'E2E Tests', status: 'queued', command: "echo 'Running E2E tests' && sleep 5", duration_secs: null, started_at: null, depends_on: ['build'], output: null, required_labels: [], max_retries: 2, attempt: 0 },
          { id: 'deploy-preview', name: 'Deploy Preview', status: 'queued', command: "echo 'Deploying preview' && sleep 1", duration_secs: null, started_at: null, depends_on: ['build'], output: null, required_labels: [], max_retries: 0, attempt: 0 },
          { id: 'deploy-web', name: 'Deploy Web', status: 'queued', command: "echo 'Deploying to production' && sleep 3", duration_secs: null, started_at: null, depends_on: ['deploy-db'], output: null, required_labels: ['linux', 'aws'], max_retries: 0, attempt: 0 },
        ],
      };
    }

    // Job durations for the simulation (ms)
    const JOB_DURATIONS: Record<string, number> = {
      'unit-tests': 2000,
      'lint': 1200,
      'typecheck': 1800,
      'build': 3000,
      'deploy-db': 1000,
      'e2e-tests': 4000,
      'deploy-preview': 1200,
      'deploy-web': 2500,
    };

    const DEPS: Record<string, string[]> = {
      'build': ['unit-tests', 'lint', 'typecheck'],
      'deploy-db': ['build'],
      'e2e-tests': ['build'],
      'deploy-preview': ['build'],
      'deploy-web': ['deploy-db'],
    };

    const FAIL_JOB = 'e2e-tests';

    // --- DOM references ---
    const runBtn = document.getElementById('demo-run') as HTMLButtonElement;
    const runStatus = document.getElementById('demo-run-status')!;
    const logPanel = document.getElementById('demo-logpanel')!;
    const logTitle = document.getElementById('log-title')!;
    const logContent = document.getElementById('log-content')!;
    const logClose = document.getElementById('log-close')!;

    // --- State ---
    let workflow = makeWorkflow();
    let timeouts: number[] = [];
    let isRunning = false;
    let runCount = 0;
    let initialized = false;

    // --- Status counts ---
    function updateCounts() {
      const counts: Record<string, number> = { queued: 0, running: 0, success: 0, failure: 0 };
      for (const job of workflow.jobs) {
        if (job.status in counts) counts[job.status]++;
      }
      for (const [k, v] of Object.entries(counts)) {
        const el = document.getElementById(`count-${k}`);
        if (el) el.textContent = String(v);
      }
    }

    // --- Log panel ---
    function onNodeClick(jobId: string) {
      const job = workflow.jobs.find((j: any) => j.id === jobId);
      if (!job) return;
      logTitle.textContent = job.name + ' \u2014 ' + job.status;

      let text = '$ ' + job.command + '\n';
      if (job.status === 'running') {
        text += 'Running...\n';
      } else if (job.status === 'success') {
        const dur = job.duration_secs ? job.duration_secs + 's' : '';
        text += '\u2713 Completed successfully' + (dur ? ' (' + dur + ')' : '') + '\n';
      } else if (job.status === 'failure') {
        text += '\u2717 Process exited with code 1\n';
      }
      if (job.output) text += job.output + '\n';

      logContent.textContent = text;
      logPanel.classList.add('visible');
    }

    function onNodeHover(_jobId: string | null) {}
    function onCanvasClick() {
      logPanel.classList.remove('visible');
    }
    function onSelectionChange(_ids: string[]) {}
    function onNodeDragEnd(_jobId: string, _x: number, _y: number) {}

    logClose.addEventListener('click', () => logPanel.classList.remove('visible'));

    // --- Render helpers ---
    function renderFull() {
      const json = JSON.stringify(workflow);
      try {
        if (!initialized) {
          resizeCanvas();
          render_workflow(CANVAS_ID, json, onNodeClick, onNodeHover, onCanvasClick, onSelectionChange, onNodeDragEnd);
          initialized = true;
        } else {
          update_workflow_data(CANVAS_ID, json);
        }
      } catch (e) {
        console.error('Render error:', e);
      }
      updateCounts();
    }

    // --- Simulation engine ---
    function schedule(delay: number, fn: () => void) {
      const t = setTimeout(fn, delay) as unknown as number;
      timeouts.push(t);
    }

    function setJobStatus(jobId: string, status: string, durationSecs?: number) {
      const job = workflow.jobs.find((j: any) => j.id === jobId);
      if (!job) return;
      job.status = status;
      if (status === 'running') {
        job.started_at = Date.now();
        job.duration_secs = null;
      }
      if (durationSecs !== undefined) {
        job.duration_secs = durationSecs;
      }
      renderFull();
    }

    function resetAll() {
      timeouts.forEach(t => clearTimeout(t));
      timeouts = [];
      workflow = makeWorkflow();
      renderFull();
      logPanel.classList.remove('visible');
    }

    function runWorkflow() {
      if (isRunning) return;
      isRunning = true;
      runCount++;
      resetAll();
      runBtn.setAttribute('disabled', '');
      runStatus.textContent = 'Running...';
      runStatus.style.color = '#d29922';

      const completed = new Set<string>();

      function tryStart(jobId: string) {
        const deps = DEPS[jobId] || [];
        const job = workflow.jobs.find((j: any) => j.id === jobId);
        if (!job || job.status !== 'queued') return;
        if (!deps.every(d => completed.has(d))) return;

        setJobStatus(jobId, 'running');

        const dur = JOB_DURATIONS[jobId] || 2000;
        const shouldFail = jobId === FAIL_JOB && runCount === 1;

        schedule(dur, () => {
          if (shouldFail) {
            setJobStatus(jobId, 'failure');
            runStatus.textContent = 'Retrying e2e-tests...';

            // Retry after pause
            schedule(1500, () => {
              job.attempt = 1;
              setJobStatus(jobId, 'running');

              schedule(dur, () => {
                setJobStatus(jobId, 'success', Math.round(dur / 1000));
                completed.add(jobId);
                tryStartAll();
                checkDone();
              });
            });
          } else {
            setJobStatus(jobId, 'success', Math.round(dur / 1000));
            completed.add(jobId);
            tryStartAll();
            checkDone();
          }
        });
      }

      function tryStartAll() {
        for (const job of workflow.jobs) {
          if (!completed.has(job.id) && job.status === 'queued') {
            tryStart(job.id);
          }
        }
      }

      function checkDone() {
        if (completed.size === workflow.jobs.length) {
          isRunning = false;
          runBtn.removeAttribute('disabled');
          runStatus.textContent = 'Completed';
          runStatus.style.color = '#3fb950';

          // Auto-restart after pause
          schedule(4000, () => {
            runStatus.textContent = '';
            runWorkflow();
          });
        }
      }

      schedule(400, tryStartAll);
    }

    // --- Events ---
    runBtn.addEventListener('click', () => {
      runCount = 0;
      runWorkflow();
    });

    // Handle resize
    window.addEventListener('resize', () => {
      resizeCanvas();
      renderFull();
    });

    // --- Initialize ---
    renderFull();
    setTimeout(() => runWorkflow(), 800);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemo);
  } else {
    initDemo();
  }
</script>
