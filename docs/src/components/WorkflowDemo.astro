---
/**
 * Animated workflow graph demo for the landing page.
 * Mirrors the real ci.yml workflow: 8 jobs with full DAG topology.
 * Pure SVG + JS — no WASM dependency. Cycles through job statuses
 * to show the visualization in action.
 */
---

<div class="demo-wrapper">
  <div class="demo-header">
    <div class="demo-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <span class="demo-title">ci.yml — workflow run</span>
    <div class="demo-controls">
      <span class="demo-status" id="demo-run-status"></span>
      <button class="demo-btn" id="demo-run" aria-label="Run workflow">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor">
          <path d="M4 2l10 6-10 6z"/>
        </svg>
        Run
      </button>
    </div>
  </div>

  <!-- Status bar -->
  <div class="demo-statusbar" id="demo-statusbar">
    <span class="status-chip queued"><span class="chip-dot"></span><span id="count-queued">8</span> queued</span>
    <span class="status-chip running"><span class="chip-dot"></span><span id="count-running">0</span> running</span>
    <span class="status-chip success"><span class="chip-dot"></span><span id="count-success">0</span> success</span>
    <span class="status-chip failure"><span class="chip-dot"></span><span id="count-failure">0</span> failure</span>
  </div>

  <svg
    id="workflow-demo"
    viewBox="0 0 960 460"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Animated workflow graph demo showing a CI pipeline"
  >
    <defs>
      <marker id="arrow" viewBox="0 0 10 7" refX="10" refY="3.5"
              markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#484f58"/>
      </marker>
      <marker id="arrow-hl" viewBox="0 0 10 7" refX="10" refY="3.5"
              markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#58a6ff"/>
      </marker>
      <marker id="arrow-active" viewBox="0 0 10 7" refX="10" refY="3.5"
              markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#3fb950"/>
      </marker>

      <!-- Icon templates -->
      <g id="icon-queued">
        <circle r="8" fill="none" stroke="#484f58" stroke-width="2"/>
      </g>
      <g id="icon-running">
        <circle r="8" fill="none" stroke="#d29922" stroke-width="2" stroke-dasharray="16 34">
          <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="1s" repeatCount="indefinite"/>
        </circle>
      </g>
      <g id="icon-success">
        <circle r="8" fill="#238636" stroke="none"/>
        <path d="M -4 0 L -1.5 3 L 4 -3" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </g>
      <g id="icon-failure">
        <circle r="8" fill="#da3633" stroke="none"/>
        <path d="M -3 -3 L 3 3 M 3 -3 L -3 3" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
      </g>
    </defs>

    <!-- Edges (matches ci.yml DAG) -->
    <g id="edges">
      <!-- unit-tests → build -->
      <path class="edge" data-from="unit-tests" data-to="build"
            d="M 205,70 C 280,70 280,230 355,230" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <!-- lint → build -->
      <path class="edge" data-from="lint" data-to="build"
            d="M 205,200 C 260,200 300,230 355,230" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <!-- typecheck → build -->
      <path class="edge" data-from="typecheck" data-to="build"
            d="M 205,340 C 280,340 280,230 355,230" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <!-- build → deploy-db -->
      <path class="edge" data-from="build" data-to="deploy-db"
            d="M 515,230 C 570,230 570,70 625,70" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <!-- build → e2e-tests -->
      <path class="edge" data-from="build" data-to="e2e-tests"
            d="M 515,230 L 625,230" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <!-- build → deploy-preview -->
      <path class="edge" data-from="build" data-to="deploy-preview"
            d="M 515,230 C 570,230 570,390 625,390" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <!-- deploy-db → deploy-web -->
      <path class="edge" data-from="deploy-db" data-to="deploy-web"
            d="M 805,70 C 860,70 860,200 860,230" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
    </g>

    <!-- Nodes (all 8 jobs from ci.yml) -->
    <g id="nodes">
      <!-- Column 1: parallel starters -->
      <g class="node" data-id="unit-tests" data-status="queued" transform="translate(45, 40)">
        <rect width="160" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">Unit Tests</text>
        <text x="46" y="47" class="node-meta">retries: 1</text>
      </g>

      <g class="node" data-id="lint" data-status="queued" transform="translate(45, 170)">
        <rect width="160" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">Lint</text>
      </g>

      <g class="node" data-id="typecheck" data-status="queued" transform="translate(45, 310)">
        <rect width="160" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">Typecheck</text>
      </g>

      <!-- Column 2: build -->
      <g class="node" data-id="build" data-status="queued" transform="translate(355, 200)">
        <rect width="160" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">Build</text>
        <text x="46" y="47" class="node-meta">linux</text>
      </g>

      <!-- Column 3: post-build -->
      <g class="node" data-id="deploy-db" data-status="queued" transform="translate(625, 40)">
        <rect width="180" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">Deploy DB</text>
        <text x="46" y="47" class="node-meta">linux, aws</text>
      </g>

      <g class="node" data-id="e2e-tests" data-status="queued" transform="translate(625, 200)">
        <rect width="180" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">E2E Tests</text>
        <text x="46" y="47" class="node-meta">retries: 2</text>
      </g>

      <g class="node" data-id="deploy-preview" data-status="queued" transform="translate(625, 360)">
        <rect width="180" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">Deploy Preview</text>
      </g>

      <!-- Column 4: final -->
      <g class="node" data-id="deploy-web" data-status="queued" transform="translate(830, 200)">
        <rect width="120" height="56" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="24" y="28"/>
        <text x="46" y="33" class="node-label">Deploy Web</text>
        <text x="46" y="47" class="node-meta">linux, aws</text>
      </g>
    </g>
  </svg>

  <!-- Log panel -->
  <div class="demo-logpanel" id="demo-logpanel">
    <div class="log-header">
      <span class="log-title" id="log-title"></span>
      <button class="log-close" id="log-close" aria-label="Close logs">&times;</button>
    </div>
    <pre class="log-content" id="log-content"></pre>
  </div>
</div>

<style>
  .demo-wrapper {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    overflow: hidden;
    max-width: 980px;
    margin: 2rem auto;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .demo-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }

  .demo-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .demo-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 13px;
    color: #8b949e;
    flex: 1;
  }

  .demo-controls {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .demo-status {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    color: #8b949e;
    transition: color 0.3s;
  }

  .demo-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #238636;
    border: 1px solid #2ea043;
    border-radius: 6px;
    color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    padding: 4px 12px;
    transition: background 0.15s;
  }

  .demo-btn:hover {
    background: #2ea043;
  }

  .demo-btn:disabled {
    background: #21262d;
    border-color: #30363d;
    color: #484f58;
    cursor: default;
  }

  /* Status bar */
  .demo-statusbar {
    display: flex;
    gap: 16px;
    padding: 8px 16px;
    background: #0d1117;
    border-bottom: 1px solid #21262d;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
  }

  .status-chip {
    display: flex;
    align-items: center;
    gap: 5px;
    color: #8b949e;
  }

  .chip-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }

  .status-chip.queued .chip-dot { background: #484f58; }
  .status-chip.running .chip-dot { background: #d29922; }
  .status-chip.success .chip-dot { background: #238636; }
  .status-chip.failure .chip-dot { background: #da3633; }

  #workflow-demo {
    display: block;
    width: 100%;
    padding: 16px;
  }

  /* Node styles */
  .node-bg {
    fill: #161b22;
    stroke: #30363d;
    stroke-width: 1.5;
    transition: stroke 0.3s, fill 0.3s;
  }

  .node:hover .node-bg {
    stroke: #58a6ff;
    fill: #1c2129;
  }

  .node { cursor: pointer; }

  .node-label {
    fill: #c9d1d9;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 13px;
    font-weight: 600;
  }

  .node-meta {
    fill: #484f58;
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    font-size: 10px;
  }

  /* Status-driven node border */
  .node[data-status="running"] .node-bg { stroke: #d29922; }
  .node[data-status="success"] .node-bg { stroke: #238636; }
  .node[data-status="failure"] .node-bg { stroke: #da3633; }

  /* Edge styles */
  .edge {
    transition: stroke 0.2s, stroke-width 0.2s;
  }

  .edge.highlighted {
    stroke: #58a6ff !important;
    stroke-width: 2.5;
    marker-end: url(#arrow-hl);
  }

  .edge.active {
    stroke: #3fb950 !important;
    stroke-width: 2.5;
    marker-end: url(#arrow-active);
  }

  /* Log panel */
  .demo-logpanel {
    display: none;
    background: #161b22;
    border-top: 1px solid #30363d;
    max-height: 160px;
    overflow: hidden;
  }

  .demo-logpanel.visible { display: block; }

  .log-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    border-bottom: 1px solid #21262d;
  }

  .log-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #c9d1d9;
  }

  .log-close {
    background: none;
    border: none;
    color: #8b949e;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    padding: 0 4px;
  }

  .log-close:hover { color: #c9d1d9; }

  .log-content {
    padding: 12px 16px;
    margin: 0;
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    font-size: 12px;
    line-height: 1.6;
    color: #8b949e;
    overflow-y: auto;
    max-height: 110px;
  }
</style>

<script>
  function initDemo() {
    const svg = document.getElementById('workflow-demo');
    if (!svg) return;

    const JOBS: Record<string, { name: string; cmd: string; dur: number }> = {
      'unit-tests':     { name: 'Unit Tests',    cmd: 'cargo test',               dur: 2000 },
      'lint':           { name: 'Lint',           cmd: 'cargo clippy',             dur: 1200 },
      'typecheck':      { name: 'Typecheck',      cmd: 'cargo check --all',        dur: 1800 },
      'build':          { name: 'Build',          cmd: 'cargo build --release',    dur: 3000 },
      'deploy-db':      { name: 'Deploy DB',      cmd: './scripts/migrate.sh',     dur: 1000 },
      'e2e-tests':      { name: 'E2E Tests',      cmd: 'playwright test',          dur: 5000 },
      'deploy-preview': { name: 'Deploy Preview', cmd: './scripts/deploy-preview.sh', dur: 1200 },
      'deploy-web':     { name: 'Deploy Web',     cmd: './scripts/deploy.sh',      dur: 2500 },
    };

    const DEPS: Record<string, string[]> = {
      'build':          ['unit-tests', 'lint', 'typecheck'],
      'deploy-db':      ['build'],
      'e2e-tests':      ['build'],
      'deploy-preview': ['build'],
      'deploy-web':     ['deploy-db'],
    };

    const FAIL_JOB = 'e2e-tests';

    let timeouts: number[] = [];
    let statuses: Record<string, string> = {};
    let startTimes: Record<string, number> = {};
    let isRunning = false;
    let runCount = 0;

    const runBtn = document.getElementById('demo-run') as HTMLButtonElement;
    const runStatus = document.getElementById('demo-run-status')!;
    const logPanel = document.getElementById('demo-logpanel')!;
    const logTitle = document.getElementById('log-title')!;
    const logContent = document.getElementById('log-content')!;
    const logClose = document.getElementById('log-close')!;

    function setStatus(jobId: string, status: string) {
      statuses[jobId] = status;
      const node = svg.querySelector(`.node[data-id="${jobId}"]`);
      if (!node) return;
      node.setAttribute('data-status', status);
      const useEl = node.querySelector('.status-icon-use');
      if (useEl) useEl.setAttribute('href', `#icon-${status}`);
      updateCounts();

      if (status === 'success' || status === 'failure') {
        svg.querySelectorAll(`.edge[data-to="${jobId}"]`).forEach((e: Element) => {
          e.classList.add('active');
        });
      }
    }

    function updateCounts() {
      const counts: Record<string, number> = { queued: 0, running: 0, success: 0, failure: 0 };
      for (const s of Object.values(statuses)) {
        if (s in counts) counts[s]++;
      }
      for (const [k, v] of Object.entries(counts)) {
        const el = document.getElementById(`count-${k}`);
        if (el) el.textContent = String(v);
      }
    }

    function highlightPath(jobId: string) {
      const visited = new Set<string>();
      function walkUp(id: string) {
        if (visited.has(id)) return;
        visited.add(id);
        svg.querySelectorAll(`.edge[data-to="${id}"]`).forEach((e: Element) => {
          e.classList.add('highlighted');
          const from = e.getAttribute('data-from');
          if (from) walkUp(from);
        });
      }
      function walkDown(id: string) {
        if (visited.has(id)) return;
        visited.add(id);
        svg.querySelectorAll(`.edge[data-from="${id}"]`).forEach((e: Element) => {
          e.classList.add('highlighted');
          const to = e.getAttribute('data-to');
          if (to) walkDown(to);
        });
      }
      walkUp(jobId);
      visited.clear();
      walkDown(jobId);
    }

    function clearHighlights() {
      svg.querySelectorAll('.edge.highlighted').forEach((e: Element) => e.classList.remove('highlighted'));
    }

    function showLogs(jobId: string) {
      const job = JOBS[jobId];
      if (!job) return;
      const status = statuses[jobId] || 'queued';
      logTitle.textContent = job.name + ' \u2014 ' + status;

      const isFail = jobId === FAIL_JOB && runCount === 1 && status === 'failure';
      const elapsed = startTimes[jobId] ? ((Date.now() - startTimes[jobId]) / 1000).toFixed(1) : '0.0';
      const durStr = (job.dur / 1000).toFixed(1);

      // Build log text safely using textContent
      let text = '[0.0s] $ ' + job.cmd + '\n';
      if (status === 'running') {
        text += '[' + elapsed + 's] Running...\n';
      } else if (status === 'success') {
        text += '\u2713 Completed successfully (' + durStr + 's)\n';
      } else if (status === 'failure') {
        text += '\u2717 Process exited with code 1\n';
        if (isFail) {
          text += '[' + durStr + 's] Error: 2 tests failed\n';
        }
      }
      logContent.textContent = text;
      logPanel.classList.add('visible');
    }

    function resetAll() {
      timeouts.forEach(t => clearTimeout(t));
      timeouts = [];
      statuses = {};
      startTimes = {};
      for (const id of Object.keys(JOBS)) {
        setStatus(id, 'queued');
      }
      svg.querySelectorAll('.edge').forEach((e: Element) => {
        e.classList.remove('active', 'highlighted');
      });
      logPanel.classList.remove('visible');
      updateCounts();
    }

    function schedule(delay: number, fn: () => void) {
      const t = setTimeout(fn, delay) as unknown as number;
      timeouts.push(t);
      return t;
    }

    function runWorkflow() {
      if (isRunning) return;
      isRunning = true;
      runCount++;
      resetAll();
      runBtn.setAttribute('disabled', '');
      runStatus.textContent = 'Running...';
      runStatus.style.color = '#d29922';

      const completed = new Set<string>();

      function tryStart(jobId: string) {
        const deps = DEPS[jobId] || [];
        if (deps.every(d => completed.has(d)) && statuses[jobId] === 'queued') {
          setStatus(jobId, 'running');
          startTimes[jobId] = Date.now();

          const job = JOBS[jobId];
          const shouldFail = jobId === FAIL_JOB && runCount === 1;

          schedule(job.dur, () => {
            if (shouldFail) {
              setStatus(jobId, 'failure');
              runStatus.textContent = 'Retrying e2e-tests...';
              schedule(1500, () => {
                setStatus(jobId, 'running');
                startTimes[jobId] = Date.now();
                schedule(job.dur, () => {
                  setStatus(jobId, 'success');
                  completed.add(jobId);
                  tryStartAll();
                  checkDone();
                });
              });
            } else {
              setStatus(jobId, 'success');
              completed.add(jobId);
              tryStartAll();
              checkDone();
            }
          });
        }
      }

      function tryStartAll() {
        for (const id of Object.keys(JOBS)) {
          if (!completed.has(id) && statuses[id] === 'queued') {
            tryStart(id);
          }
        }
      }

      function checkDone() {
        if (completed.size === Object.keys(JOBS).length) {
          isRunning = false;
          runBtn.removeAttribute('disabled');
          runStatus.textContent = 'Completed';
          runStatus.style.color = '#3fb950';

          schedule(4000, () => {
            runStatus.textContent = '';
            runWorkflow();
          });
        }
      }

      schedule(400, tryStartAll);
    }

    // Event listeners
    svg.querySelectorAll('.node').forEach((node: Element) => {
      node.addEventListener('mouseenter', () => {
        const id = node.getAttribute('data-id');
        if (id) highlightPath(id);
      });
      node.addEventListener('mouseleave', clearHighlights);
      node.addEventListener('click', () => {
        const id = node.getAttribute('data-id');
        if (id) showLogs(id);
      });
    });

    runBtn.addEventListener('click', () => {
      runCount = 0;
      runWorkflow();
    });

    logClose.addEventListener('click', () => {
      logPanel.classList.remove('visible');
    });

    // Auto-start
    setTimeout(() => runWorkflow(), 800);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemo);
  } else {
    initDemo();
  }
</script>
