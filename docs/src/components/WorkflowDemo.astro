---
/**
 * Animated workflow graph demo for the landing page.
 * Mirrors the real ci.yml workflow: 8 jobs with full DAG topology.
 * Features: drag-and-drop nodes, YAML source view, animated execution.
 * Pure SVG + JS — no WASM dependency.
 */
---

<div class="demo-wrapper">
  <div class="demo-header">
    <div class="demo-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <span class="demo-title">ci.yml — workflow run</span>
    <div class="demo-controls">
      <span class="demo-status" id="demo-run-status"></span>
      <div class="demo-tabs">
        <button class="tab-btn active" id="tab-graph" aria-label="Graph view">Graph</button>
        <button class="tab-btn" id="tab-yaml" aria-label="YAML view">YAML</button>
      </div>
      <button class="demo-btn" id="demo-run" aria-label="Run workflow">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor">
          <path d="M4 2l10 6-10 6z"/>
        </svg>
        Run
      </button>
    </div>
  </div>

  <!-- Status bar -->
  <div class="demo-statusbar" id="demo-statusbar">
    <span class="status-chip queued"><span class="chip-dot"></span><span id="count-queued">8</span> queued</span>
    <span class="status-chip running"><span class="chip-dot"></span><span id="count-running">0</span> running</span>
    <span class="status-chip success"><span class="chip-dot"></span><span id="count-success">0</span> success</span>
    <span class="status-chip failure"><span class="chip-dot"></span><span id="count-failure">0</span> failure</span>
  </div>

  <!-- Graph view -->
  <div class="demo-view" id="view-graph">
    <svg
      id="workflow-demo"
      viewBox="0 0 880 420"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Animated workflow graph demo showing a CI pipeline"
    >
      <defs>
        <!-- Icon templates -->
        <g id="icon-queued">
          <circle r="8" fill="none" stroke="#484f58" stroke-width="2"/>
        </g>
        <g id="icon-running">
          <circle r="8" fill="none" stroke="#d29922" stroke-width="2" stroke-dasharray="16 34">
            <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="1s" repeatCount="indefinite"/>
          </circle>
        </g>
        <g id="icon-success">
          <circle r="8" fill="#238636" stroke="none"/>
          <path d="M -4 0 L -1.5 3 L 4 -3" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </g>
        <g id="icon-failure">
          <circle r="8" fill="#da3633" stroke="none"/>
          <path d="M -3 -3 L 3 3 M 3 -3 L -3 3" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </g>
      </defs>

      <!-- Edges (dynamically updated on drag) -->
      <g id="edges"></g>

      <!-- Nodes -->
      <g id="nodes"></g>
    </svg>
  </div>

  <!-- YAML view -->
  <div class="demo-view hidden" id="view-yaml">
    <pre class="yaml-source"><code id="yaml-content">name: CI
on: push

jobs:
  unit-tests:
    name: Unit Tests
    run: echo 'Running unit tests' && sleep 2
    retries: 1

  lint:
    name: Lint
    run: echo 'Running linter' && sleep 1

  typecheck:
    name: Typecheck
    run: echo 'Running typecheck' && sleep 2

  build:
    name: Build
    needs: [unit-tests, lint, typecheck]
    run: echo 'Building project' && sleep 3
    labels: [linux]

  deploy-db:
    name: Deploy DB Migrations
    needs: [build]
    run: echo 'Deploying DB migrations' && sleep 1
    labels: [linux, aws]

  e2e-tests:
    name: E2E Tests
    needs: [build]
    run: echo 'Running E2E tests' && sleep 5
    retries: 2

  deploy-preview:
    name: Deploy Preview
    needs: [build]
    run: echo 'Deploying preview' && sleep 1

  deploy-web:
    name: Deploy Web
    needs: [deploy-db]
    run: echo 'Deploying to production' && sleep 3
    labels: [linux, aws]</code></pre>
  </div>

  <!-- Log panel -->
  <div class="demo-logpanel" id="demo-logpanel">
    <div class="log-header">
      <span class="log-title" id="log-title"></span>
      <button class="log-close" id="log-close" aria-label="Close logs">&times;</button>
    </div>
    <pre class="log-content" id="log-content"></pre>
  </div>
</div>

<style is:global>
  .demo-wrapper {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    overflow: hidden;
    max-width: 920px;
    margin: 2rem auto;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .demo-wrapper .demo-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }

  .demo-wrapper .demo-dots { display: flex; gap: 6px; }
  .demo-wrapper .dot { width: 12px; height: 12px; border-radius: 50%; }
  .demo-wrapper .dot.red { background: #ff5f57; }
  .demo-wrapper .dot.yellow { background: #febc2e; }
  .demo-wrapper .dot.green { background: #28c840; }

  .demo-wrapper .demo-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 13px;
    color: #8b949e;
    flex: 1;
  }

  .demo-wrapper .demo-controls { display: flex; align-items: center; gap: 10px; }

  .demo-wrapper .demo-status {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    color: #8b949e;
    transition: color 0.3s;
  }

  /* Tabs */
  .demo-wrapper .demo-tabs {
    display: flex;
    background: #21262d;
    border-radius: 6px;
    padding: 2px;
  }

  .demo-wrapper .tab-btn {
    all: unset;
    display: inline-block;
    border-radius: 4px;
    color: #8b949e;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    padding: 3px 10px;
    line-height: 1.4;
    transition: background 0.15s, color 0.15s;
    box-sizing: border-box;
  }

  .demo-wrapper .tab-btn:hover { color: #c9d1d9; }
  .demo-wrapper .tab-btn.active { background: #30363d; color: #c9d1d9; }

  .demo-wrapper .demo-btn {
    all: unset;
    display: flex;
    align-items: center;
    gap: 6px;
    background: #238636;
    border: 1px solid #2ea043;
    border-radius: 6px;
    color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    padding: 4px 12px;
    line-height: 1.4;
    box-sizing: border-box;
    transition: background 0.15s;
  }

  .demo-wrapper .demo-btn:hover { background: #2ea043; }
  .demo-wrapper .demo-btn:disabled { background: #21262d; border-color: #30363d; color: #484f58; cursor: default; }

  /* Status bar */
  .demo-wrapper .demo-statusbar {
    display: flex;
    gap: 16px;
    padding: 8px 16px;
    background: #0d1117;
    border-bottom: 1px solid #21262d;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
  }

  .demo-wrapper .status-chip { display: flex; align-items: center; gap: 5px; color: #8b949e; }
  .demo-wrapper .chip-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .demo-wrapper .status-chip.queued .chip-dot { background: #484f58; }
  .demo-wrapper .status-chip.running .chip-dot { background: #d29922; }
  .demo-wrapper .status-chip.success .chip-dot { background: #238636; }
  .demo-wrapper .status-chip.failure .chip-dot { background: #da3633; }

  /* Views */
  .demo-wrapper .demo-view { min-height: 340px; }
  .demo-wrapper .demo-view.hidden { display: none; }

  .demo-wrapper #workflow-demo {
    display: block;
    width: 100%;
    padding: 12px;
    user-select: none;
  }

  /* YAML view */
  .demo-wrapper .yaml-source {
    margin: 0;
    padding: 20px 24px;
    background: #0d1117;
    color: #c9d1d9;
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    font-size: 13px;
    line-height: 1.55;
    overflow-x: auto;
    max-height: 380px;
    overflow-y: auto;
  }

  /* SVG text defaults */
  .demo-wrapper #workflow-demo text {
    fill: #c9d1d9;
    stroke: none;
  }

  /* Node styles */
  .demo-wrapper .node-bg {
    fill: #161b22;
    stroke: #30363d;
    stroke-width: 1.5;
    transition: stroke 0.3s, fill 0.3s;
  }

  .demo-wrapper .node:hover .node-bg { stroke: #58a6ff; fill: #1c2129; }
  .demo-wrapper .node { cursor: grab; }
  .demo-wrapper .node.dragging { cursor: grabbing; }

  .demo-wrapper .node-label {
    fill: #c9d1d9;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 600;
    pointer-events: none;
  }

  .demo-wrapper .node-meta {
    fill: #6e7681;
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    font-size: 9px;
    pointer-events: none;
  }

  /* Status-driven node border */
  .demo-wrapper .node[data-status="running"] .node-bg { stroke: #d29922; }
  .demo-wrapper .node[data-status="success"] .node-bg { stroke: #238636; }
  .demo-wrapper .node[data-status="failure"] .node-bg { stroke: #da3633; }

  /* Edge styles */
  .demo-wrapper .edge { transition: stroke 0.15s, stroke-width 0.15s; }
  .demo-wrapper .edge.highlighted { stroke: #58a6ff !important; stroke-width: 2.5; }
  .demo-wrapper .edge.active { stroke: #3fb950 !important; stroke-width: 2.5; }

  /* Log panel */
  .demo-wrapper .demo-logpanel { display: none; background: #161b22; border-top: 1px solid #30363d; max-height: 140px; overflow: hidden; }
  .demo-wrapper .demo-logpanel.visible { display: block; }
  .demo-wrapper .log-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; border-bottom: 1px solid #21262d; }
  .demo-wrapper .log-title { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif; font-size: 12px; font-weight: 600; color: #c9d1d9; }
  .demo-wrapper .log-close { all: unset; color: #8b949e; cursor: pointer; font-size: 18px; line-height: 1; padding: 0 4px; }
  .demo-wrapper .log-close:hover { color: #c9d1d9; }
  .demo-wrapper .log-content { padding: 10px 16px; margin: 0; font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace; font-size: 12px; line-height: 1.6; color: #8b949e; overflow-y: auto; max-height: 90px; }
</style>

<script>
  function initDemo() {
    const svg = document.getElementById('workflow-demo') as unknown as SVGSVGElement;
    if (!svg) return;

    const edgesG = document.getElementById('edges')!;
    const nodesG = document.getElementById('nodes')!;

    // --- Node layout data (compact to fit all 8 nodes) ---
    const NODE_W = 140;
    const NODE_H = 50;

    interface NodeDef {
      id: string;
      name: string;
      cmd: string;
      dur: number;
      x: number;
      y: number;
      w: number;
      meta?: string;
    }

    const nodeData: NodeDef[] = [
      { id: 'unit-tests',     name: 'Unit Tests',      cmd: 'cargo test',                     dur: 2000, x: 30,  y: 30,  w: NODE_W, meta: 'retries: 1' },
      { id: 'lint',           name: 'Lint',             cmd: 'cargo clippy',                   dur: 1200, x: 30,  y: 150, w: NODE_W },
      { id: 'typecheck',      name: 'Typecheck',        cmd: 'cargo check --all',              dur: 1800, x: 30,  y: 270, w: NODE_W },
      { id: 'build',          name: 'Build',            cmd: 'cargo build --release',          dur: 3000, x: 260, y: 150, w: NODE_W, meta: 'linux' },
      { id: 'deploy-db',      name: 'Deploy DB',        cmd: './scripts/migrate.sh',           dur: 1000, x: 480, y: 30,  w: 150, meta: 'linux, aws' },
      { id: 'e2e-tests',      name: 'E2E Tests',        cmd: 'playwright test',                dur: 5000, x: 480, y: 150, w: 150, meta: 'retries: 2' },
      { id: 'deploy-preview', name: 'Deploy Preview',   cmd: './scripts/deploy-preview.sh',    dur: 1200, x: 480, y: 270, w: 150 },
      { id: 'deploy-web',     name: 'Deploy Web',       cmd: './scripts/deploy.sh',            dur: 2500, x: 710, y: 30,  w: 140, meta: 'linux, aws' },
    ];

    const EDGES: [string, string][] = [
      ['unit-tests', 'build'],
      ['lint', 'build'],
      ['typecheck', 'build'],
      ['build', 'deploy-db'],
      ['build', 'e2e-tests'],
      ['build', 'deploy-preview'],
      ['deploy-db', 'deploy-web'],
    ];

    const DEPS: Record<string, string[]> = {
      'build':          ['unit-tests', 'lint', 'typecheck'],
      'deploy-db':      ['build'],
      'e2e-tests':      ['build'],
      'deploy-preview': ['build'],
      'deploy-web':     ['deploy-db'],
    };

    const FAIL_JOB = 'e2e-tests';

    // Lookup maps
    const nodeMap = new Map<string, NodeDef>();
    for (const n of nodeData) nodeMap.set(n.id, n);

    // --- Build SVG nodes ---
    function buildNodes() {
      nodesG.textContent = '';
      for (const n of nodeData) {
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.classList.add('node');
        g.setAttribute('data-id', n.id);
        g.setAttribute('data-status', 'queued');
        g.setAttribute('transform', `translate(${n.x}, ${n.y})`);

        const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        rect.setAttribute('width', String(n.w));
        rect.setAttribute('height', String(NODE_H));
        rect.setAttribute('rx', '8');
        rect.classList.add('node-bg');
        g.appendChild(rect);

        const use = document.createElementNS('http://www.w3.org/2000/svg', 'use');
        use.setAttribute('href', '#icon-queued');
        use.classList.add('status-icon-use');
        use.setAttribute('x', '20');
        use.setAttribute('y', String(NODE_H / 2));
        g.appendChild(use);

        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('x', '40');
        label.setAttribute('y', n.meta ? String(NODE_H / 2 - 3) : String(NODE_H / 2 + 4));
        label.classList.add('node-label');
        label.textContent = n.name;
        g.appendChild(label);

        if (n.meta) {
          const meta = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          meta.setAttribute('x', '40');
          meta.setAttribute('y', String(NODE_H / 2 + 11));
          meta.classList.add('node-meta');
          meta.textContent = n.meta;
          g.appendChild(meta);
        }

        nodesG.appendChild(g);
      }
    }

    // --- Build SVG edges (recalculated on drag) ---
    function updateEdges() {
      edgesG.textContent = '';
      for (const [fromId, toId] of EDGES) {
        const from = nodeMap.get(fromId)!;
        const to = nodeMap.get(toId)!;

        const x1 = from.x + from.w;
        const y1 = from.y + NODE_H / 2;
        const x2 = to.x;
        const y2 = to.y + NODE_H / 2;
        const mx = (x1 + x2) / 2;

        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.classList.add('edge');
        path.setAttribute('data-from', fromId);
        path.setAttribute('data-to', toId);
        path.setAttribute('d', `M ${x1},${y1} C ${mx},${y1} ${mx},${y2} ${x2},${y2}`);
        path.setAttribute('fill', 'none');
        path.setAttribute('stroke', '#484f58');
        path.setAttribute('stroke-width', '2');

        // Re-apply active/highlighted classes based on current status
        const toStatus = statuses[toId];
        if (toStatus === 'success' || toStatus === 'failure') {
          path.classList.add('active');
        }

        edgesG.appendChild(path);
      }
    }

    // --- State ---
    let timeouts: number[] = [];
    let statuses: Record<string, string> = {};
    let startTimes: Record<string, number> = {};
    let isRunning = false;
    let runCount = 0;

    const runBtn = document.getElementById('demo-run') as HTMLButtonElement;
    const runStatus = document.getElementById('demo-run-status')!;
    const logPanel = document.getElementById('demo-logpanel')!;
    const logTitle = document.getElementById('log-title')!;
    const logContent = document.getElementById('log-content')!;
    const logClose = document.getElementById('log-close')!;
    const tabGraph = document.getElementById('tab-graph')!;
    const tabYaml = document.getElementById('tab-yaml')!;
    const viewGraph = document.getElementById('view-graph')!;
    const viewYaml = document.getElementById('view-yaml')!;

    // --- Tab switching ---
    tabGraph.addEventListener('click', () => {
      tabGraph.classList.add('active');
      tabYaml.classList.remove('active');
      viewGraph.classList.remove('hidden');
      viewYaml.classList.add('hidden');
    });
    tabYaml.addEventListener('click', () => {
      tabYaml.classList.add('active');
      tabGraph.classList.remove('active');
      viewYaml.classList.remove('hidden');
      viewGraph.classList.add('hidden');
    });

    // --- Status management ---
    function setStatus(jobId: string, status: string) {
      statuses[jobId] = status;
      const node = svg.querySelector(`.node[data-id="${jobId}"]`);
      if (!node) return;
      node.setAttribute('data-status', status);
      const useEl = node.querySelector('.status-icon-use');
      if (useEl) useEl.setAttribute('href', `#icon-${status}`);
      updateCounts();

      if (status === 'success' || status === 'failure') {
        svg.querySelectorAll(`.edge[data-to="${jobId}"]`).forEach((e: Element) => {
          e.classList.add('active');
        });
      }
    }

    function updateCounts() {
      const counts: Record<string, number> = { queued: 0, running: 0, success: 0, failure: 0 };
      for (const s of Object.values(statuses)) {
        if (s in counts) counts[s]++;
      }
      for (const [k, v] of Object.entries(counts)) {
        const el = document.getElementById(`count-${k}`);
        if (el) el.textContent = String(v);
      }
    }

    // --- Edge highlighting ---
    function highlightPath(jobId: string) {
      const visited = new Set<string>();
      function walkUp(id: string) {
        if (visited.has(id)) return;
        visited.add(id);
        svg.querySelectorAll(`.edge[data-to="${id}"]`).forEach((e: Element) => {
          e.classList.add('highlighted');
          const from = e.getAttribute('data-from');
          if (from) walkUp(from);
        });
      }
      function walkDown(id: string) {
        if (visited.has(id)) return;
        visited.add(id);
        svg.querySelectorAll(`.edge[data-from="${id}"]`).forEach((e: Element) => {
          e.classList.add('highlighted');
          const to = e.getAttribute('data-to');
          if (to) walkDown(to);
        });
      }
      walkUp(jobId);
      visited.clear();
      walkDown(jobId);
    }

    function clearHighlights() {
      svg.querySelectorAll('.edge.highlighted').forEach((e: Element) => e.classList.remove('highlighted'));
    }

    // --- Log panel ---
    function showLogs(jobId: string) {
      const nd = nodeMap.get(jobId);
      if (!nd) return;
      const status = statuses[jobId] || 'queued';
      logTitle.textContent = nd.name + ' \u2014 ' + status;

      const isFail = jobId === FAIL_JOB && runCount === 1 && status === 'failure';
      const elapsed = startTimes[jobId] ? ((Date.now() - startTimes[jobId]) / 1000).toFixed(1) : '0.0';
      const durStr = (nd.dur / 1000).toFixed(1);

      let text = '[0.0s] $ ' + nd.cmd + '\n';
      if (status === 'running') {
        text += '[' + elapsed + 's] Running...\n';
      } else if (status === 'success') {
        text += '\u2713 Completed successfully (' + durStr + 's)\n';
      } else if (status === 'failure') {
        text += '\u2717 Process exited with code 1\n';
        if (isFail) text += '[' + durStr + 's] Error: 2 tests failed\n';
      }
      logContent.textContent = text;
      logPanel.classList.add('visible');
    }

    // --- Drag and drop ---
    let dragNode: NodeDef | null = null;
    let dragOffset = { x: 0, y: 0 };

    function svgPoint(e: MouseEvent | Touch) {
      const pt = svg.createSVGPoint();
      pt.x = e.clientX;
      pt.y = e.clientY;
      const ctm = svg.getScreenCTM();
      if (!ctm) return { x: 0, y: 0 };
      const svgP = pt.matrixTransform(ctm.inverse());
      return { x: svgP.x, y: svgP.y };
    }

    function onPointerDown(e: PointerEvent) {
      const nodeEl = (e.target as Element).closest('.node');
      if (!nodeEl) return;
      const id = nodeEl.getAttribute('data-id');
      if (!id) return;
      const nd = nodeMap.get(id);
      if (!nd) return;

      e.preventDefault();
      dragNode = nd;
      const p = svgPoint(e);
      dragOffset.x = p.x - nd.x;
      dragOffset.y = p.y - nd.y;
      nodeEl.classList.add('dragging');
      svg.style.cursor = 'grabbing';
      svg.setPointerCapture(e.pointerId);
    }

    function onPointerMove(e: PointerEvent) {
      if (!dragNode) return;
      e.preventDefault();
      const p = svgPoint(e);
      dragNode.x = p.x - dragOffset.x;
      dragNode.y = p.y - dragOffset.y;

      const nodeEl = svg.querySelector(`.node[data-id="${dragNode.id}"]`);
      if (nodeEl) {
        nodeEl.setAttribute('transform', `translate(${dragNode.x}, ${dragNode.y})`);
      }
      updateEdges();
    }

    function onPointerUp(e: PointerEvent) {
      if (!dragNode) return;
      const nodeEl = svg.querySelector(`.node[data-id="${dragNode.id}"]`);
      if (nodeEl) nodeEl.classList.remove('dragging');
      svg.style.cursor = '';
      dragNode = null;
    }

    svg.addEventListener('pointerdown', onPointerDown);
    svg.addEventListener('pointermove', onPointerMove);
    svg.addEventListener('pointerup', onPointerUp);

    // --- Reset / schedule ---
    function resetAll() {
      timeouts.forEach(t => clearTimeout(t));
      timeouts = [];
      statuses = {};
      startTimes = {};
      for (const n of nodeData) setStatus(n.id, 'queued');
      svg.querySelectorAll('.edge').forEach((e: Element) => {
        e.classList.remove('active', 'highlighted');
      });
      logPanel.classList.remove('visible');
      updateCounts();
    }

    function schedule(delay: number, fn: () => void) {
      const t = setTimeout(fn, delay) as unknown as number;
      timeouts.push(t);
      return t;
    }

    // --- Run workflow ---
    function runWorkflow() {
      if (isRunning) return;
      isRunning = true;
      runCount++;
      resetAll();
      runBtn.setAttribute('disabled', '');
      runStatus.textContent = 'Running...';
      runStatus.style.color = '#d29922';

      const completed = new Set<string>();

      function tryStart(jobId: string) {
        const deps = DEPS[jobId] || [];
        if (deps.every(d => completed.has(d)) && statuses[jobId] === 'queued') {
          setStatus(jobId, 'running');
          startTimes[jobId] = Date.now();

          const nd = nodeMap.get(jobId)!;
          const shouldFail = jobId === FAIL_JOB && runCount === 1;

          schedule(nd.dur, () => {
            if (shouldFail) {
              setStatus(jobId, 'failure');
              runStatus.textContent = 'Retrying e2e-tests...';
              schedule(1500, () => {
                setStatus(jobId, 'running');
                startTimes[jobId] = Date.now();
                schedule(nd.dur, () => {
                  setStatus(jobId, 'success');
                  completed.add(jobId);
                  tryStartAll();
                  checkDone();
                });
              });
            } else {
              setStatus(jobId, 'success');
              completed.add(jobId);
              tryStartAll();
              checkDone();
            }
          });
        }
      }

      function tryStartAll() {
        for (const n of nodeData) {
          if (!completed.has(n.id) && statuses[n.id] === 'queued') {
            tryStart(n.id);
          }
        }
      }

      function checkDone() {
        if (completed.size === nodeData.length) {
          isRunning = false;
          runBtn.removeAttribute('disabled');
          runStatus.textContent = 'Completed';
          runStatus.style.color = '#3fb950';

          schedule(4000, () => {
            runStatus.textContent = '';
            runWorkflow();
          });
        }
      }

      schedule(400, tryStartAll);
    }

    // --- Event listeners for nodes ---
    function attachNodeListeners() {
      svg.querySelectorAll('.node').forEach((node: Element) => {
        node.addEventListener('mouseenter', () => {
          const id = node.getAttribute('data-id');
          if (id && !dragNode) highlightPath(id);
        });
        node.addEventListener('mouseleave', () => {
          if (!dragNode) clearHighlights();
        });
        node.addEventListener('click', (e) => {
          // Don't show logs if we just finished dragging
          const id = node.getAttribute('data-id');
          if (id) showLogs(id);
        });
      });
    }

    runBtn.addEventListener('click', () => {
      runCount = 0;
      runWorkflow();
    });

    logClose.addEventListener('click', () => {
      logPanel.classList.remove('visible');
    });

    // --- Initialize ---
    buildNodes();
    updateEdges();
    attachNodeListeners();

    // Auto-start animation
    setTimeout(() => runWorkflow(), 800);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemo);
  } else {
    initDemo();
  }
</script>
