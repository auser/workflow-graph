---
/**
 * Animated workflow graph demo for the landing page.
 * Pure SVG + JS — no WASM dependency. Cycles through job statuses
 * to show the visualization in action.
 */
---

<div class="demo-wrapper">
  <div class="demo-header">
    <div class="demo-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <span class="demo-title">ci.yml — workflow run</span>
    <button class="demo-replay" id="demo-replay" aria-label="Replay animation">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
        <path d="M1.705 8.005a.75.75 0 0 1 .834.656 5.5 5.5 0 0 0 9.592 2.97l-1.204-1.204a.25.25 0 0 1 .177-.427h3.646a.25.25 0 0 1 .25.25v3.646a.25.25 0 0 1-.427.177l-1.071-1.071A7.002 7.002 0 0 1 1.05 8.84a.75.75 0 0 1 .656-.834ZM8 2.5a5.487 5.487 0 0 0-4.131 1.869l1.204 1.204A.25.25 0 0 1 4.896 6H1.25A.25.25 0 0 1 1 5.75V2.104a.25.25 0 0 1 .427-.177l1.071 1.071A7.002 7.002 0 0 1 14.95 7.16a.75.75 0 0 1-1.49.178A5.5 5.5 0 0 0 8 2.5Z"/>
      </svg>
    </button>
  </div>
  <svg
    id="workflow-demo"
    viewBox="0 0 820 380"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Animated workflow graph demo showing a CI pipeline"
  >
    <defs>
      <marker id="arrow" viewBox="0 0 10 7" refX="10" refY="3.5"
              markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#484f58"/>
      </marker>
      <marker id="arrow-highlight" viewBox="0 0 10 7" refX="10" refY="3.5"
              markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#58a6ff"/>
      </marker>

      <!-- Pre-defined icon templates -->
      <g id="icon-queued">
        <circle r="8" fill="none" stroke="#484f58" stroke-width="2"/>
      </g>
      <g id="icon-running">
        <circle r="8" fill="none" stroke="#d29922" stroke-width="2" stroke-dasharray="16 34">
          <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="1s" repeatCount="indefinite"/>
        </circle>
      </g>
      <g id="icon-success">
        <circle r="8" fill="#238636" stroke="none"/>
        <path d="M -4 0 L -1.5 3 L 4 -3" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </g>
      <g id="icon-failure">
        <circle r="8" fill="#da3633" stroke="none"/>
        <path d="M -3 -3 L 3 3 M 3 -3 L -3 3" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
      </g>
    </defs>

    <!-- Edges -->
    <g id="edges">
      <path class="edge" data-from="unit-tests" data-to="build"
            d="M 205,60 C 270,60 270,190 335,190" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <path class="edge" data-from="lint" data-to="build"
            d="M 205,190 L 335,190" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <path class="edge" data-from="typecheck" data-to="build"
            d="M 205,320 C 270,320 270,190 335,190" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <path class="edge" data-from="build" data-to="deploy-db"
            d="M 495,190 C 545,190 545,60 595,60" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <path class="edge" data-from="build" data-to="e2e-tests"
            d="M 495,190 L 595,190" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
      <path class="edge" data-from="build" data-to="deploy-preview"
            d="M 495,190 C 545,190 545,320 595,320" fill="none" stroke="#484f58" stroke-width="2" marker-end="url(#arrow)"/>
    </g>

    <!-- Nodes -->
    <g id="nodes">
      <g class="node" data-id="unit-tests" data-status="queued" transform="translate(45, 30)">
        <rect width="160" height="60" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="20" y="30"/>
        <text x="42" y="35" class="node-label">Unit Tests</text>
      </g>

      <g class="node" data-id="lint" data-status="queued" transform="translate(45, 160)">
        <rect width="160" height="60" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="20" y="30"/>
        <text x="42" y="35" class="node-label">Lint</text>
      </g>

      <g class="node" data-id="typecheck" data-status="queued" transform="translate(45, 290)">
        <rect width="160" height="60" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="20" y="30"/>
        <text x="42" y="35" class="node-label">Typecheck</text>
      </g>

      <g class="node" data-id="build" data-status="queued" transform="translate(335, 160)">
        <rect width="160" height="60" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="20" y="30"/>
        <text x="42" y="35" class="node-label">Build</text>
      </g>

      <g class="node" data-id="deploy-db" data-status="queued" transform="translate(595, 30)">
        <rect width="180" height="60" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="20" y="30"/>
        <text x="42" y="35" class="node-label">Deploy DB</text>
      </g>

      <g class="node" data-id="e2e-tests" data-status="queued" transform="translate(595, 160)">
        <rect width="180" height="60" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="20" y="30"/>
        <text x="42" y="35" class="node-label">E2E Tests</text>
      </g>

      <g class="node" data-id="deploy-preview" data-status="queued" transform="translate(595, 290)">
        <rect width="180" height="60" rx="10" class="node-bg"/>
        <use href="#icon-queued" class="status-icon-use" x="20" y="30"/>
        <text x="42" y="35" class="node-label">Deploy Preview</text>
      </g>
    </g>
  </svg>
</div>

<style>
  .demo-wrapper {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    overflow: hidden;
    max-width: 860px;
    margin: 2rem auto;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .demo-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }

  .demo-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .demo-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 13px;
    color: #8b949e;
    flex: 1;
  }

  .demo-replay {
    background: none;
    border: 1px solid #30363d;
    border-radius: 6px;
    color: #8b949e;
    cursor: pointer;
    padding: 4px 8px;
    display: flex;
    align-items: center;
    transition: color 0.15s, border-color 0.15s;
  }

  .demo-replay:hover {
    color: #c9d1d9;
    border-color: #484f58;
  }

  #workflow-demo {
    display: block;
    width: 100%;
    padding: 16px;
  }

  /* Node styles */
  .node-bg {
    fill: #161b22;
    stroke: #30363d;
    stroke-width: 1.5;
    transition: stroke 0.3s;
  }

  .node:hover .node-bg {
    stroke: #58a6ff;
  }

  .node { cursor: pointer; }

  .node-label {
    fill: #c9d1d9;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
    font-size: 13px;
    font-weight: 500;
  }

  /* Status-driven node border */
  .node[data-status="running"] .node-bg {
    stroke: #d29922;
  }

  .node[data-status="success"] .node-bg {
    stroke: #238636;
  }

  .node[data-status="failure"] .node-bg {
    stroke: #da3633;
  }

  /* Edge styles */
  .edge {
    transition: stroke 0.2s;
  }

  .edge.highlighted {
    stroke: #58a6ff !important;
    marker-end: url(#arrow-highlight);
  }
</style>

<script>
  function initDemo() {
    const TIMELINE = [
      [800,  'unit-tests',     'running'],
      [0,    'lint',           'running'],
      [0,    'typecheck',      'running'],
      [1200, 'lint',           'success'],
      [600,  'typecheck',      'success'],
      [800,  'unit-tests',     'success'],
      [300,  'build',          'running'],
      [2000, 'build',          'success'],
      [300,  'deploy-db',      'running'],
      [0,    'e2e-tests',      'running'],
      [0,    'deploy-preview', 'running'],
      [800,  'deploy-preview', 'success'],
      [400,  'deploy-db',      'success'],
      [1600, 'e2e-tests',      'failure'],
    ];

    const svg = document.getElementById('workflow-demo');
    if (!svg) return;

    function setStatus(jobId: string, status: string) {
      const node = svg.querySelector(`.node[data-id="${jobId}"]`);
      if (!node) return;
      node.setAttribute('data-status', status);
      const useEl = node.querySelector('.status-icon-use');
      if (useEl) {
        useEl.setAttribute('href', `#icon-${status}`);
      }
    }

    function highlightEdges(jobId: string) {
      svg.querySelectorAll('.edge').forEach((e: Element) => {
        if (e.getAttribute('data-from') === jobId || e.getAttribute('data-to') === jobId) {
          e.classList.add('highlighted');
        }
      });
    }

    function clearHighlights() {
      svg.querySelectorAll('.edge').forEach((e: Element) => e.classList.remove('highlighted'));
    }

    let timeouts: number[] = [];

    function runAnimation() {
      timeouts.forEach(t => clearTimeout(t));
      timeouts = [];

      // Reset all nodes to queued
      svg.querySelectorAll('.node').forEach((n: Element) => {
        const id = n.getAttribute('data-id');
        if (id) setStatus(id, 'queued');
      });
      clearHighlights();

      let cumulative = 500;
      for (const [delay, jobId, status] of TIMELINE) {
        cumulative += delay as number;
        const jid = jobId as string;
        const st = status as string;
        const t = cumulative;
        timeouts.push(setTimeout(() => setStatus(jid, st), t) as unknown as number);
      }

      // Loop
      timeouts.push(setTimeout(() => runAnimation(), cumulative + 3000) as unknown as number);
    }

    // Hover highlighting
    svg.querySelectorAll('.node').forEach((node: Element) => {
      node.addEventListener('mouseenter', () => {
        const id = node.getAttribute('data-id');
        if (id) highlightEdges(id);
      });
      node.addEventListener('mouseleave', clearHighlights);
    });

    // Replay button
    document.getElementById('demo-replay')?.addEventListener('click', runAnimation);

    runAnimation();
  }

  // Run after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemo);
  } else {
    initDemo();
  }
</script>
